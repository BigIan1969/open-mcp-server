{
  "name": "mcp-server",
  "version": "1.0.0",
  "description": "Custom MCP Server with Jest unit testing",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --coverage",
    "test:py": "pytest",
    "test:all": "npm test && pytest"
  },
  "keywords": [
    "mcp",
    "server",
    "unit-testing",
    "jest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "fast-glob": "^3.3.3",
    "imapflow": "^1.3.3",
    "net-snmp": "^3.26.3",
    "node-fetch": "3.x",
    "nodemailer": "^8.0.7",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.26.0",
    "@playwright/test": "^1.60.0",
    "@types/jest": "^29.5.11",
    "@types/node": "^25.7.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0"
  }

}
